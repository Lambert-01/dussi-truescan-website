---
import { company } from "../data/company";

const {
  title = `${company.name} | Non-Destructive Testing in Rwanda`,
  description = `${company.name} provides NDT inspection, technical consultancy, and professional training from Kigali, Rwanda.`,
} = Astro.props;
---
<!doctype html>
<html class="no-js" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="shortcut icon" type="image/x-icon" href="/assets/img/favicon.ico" />
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/owl.carousel.min.css" />
    <link rel="stylesheet" href="/assets/css/slicknav.css" />
    <link rel="stylesheet" href="/assets/css/flaticon.css" />
    <link rel="stylesheet" href="/assets/css/animate.min.css" />
    <link rel="stylesheet" href="/assets/css/magnific-popup.css" />
    <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css" />
    <link rel="stylesheet" href="/assets/css/themify-icons.css" />
    <link rel="stylesheet" href="/assets/css/slick.css" />
    <link rel="stylesheet" href="/assets/css/nice-select.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <style>
      :root {
        --dussi-red: #c73138;
        --dussi-blue: #10243f;
        --dussi-ink: #1d2742;
      }

      .brand-logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--dussi-blue);
        font-family: "Teko", sans-serif;
        font-size: 27px;
        font-weight: 700;
        line-height: 1;
      }

      .brand-logo:hover {
        color: var(--dussi-blue);
      }

      .brand-logo span:first-child {
        width: 52px;
        height: 52px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: var(--dussi-red);
        color: #fff;
        font-family: "Barlow", sans-serif;
        font-size: 16px;
        letter-spacing: 0;
      }

      .brand-logo small {
        display: block;
        color: #6c7487;
        font-family: "Barlow", sans-serif;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-top: 3px;
      }

      .main-menu ul li a.active {
        color: #f15f22;
      }

      .slider-area .dussi-slider {
        background:
          linear-gradient(rgba(16, 36, 63, 0.76), rgba(16, 36, 63, 0.74)),
          url("/assets/img/hero/h1_hero.jpg");
        background-size: cover;
        background-position: center;
      }

      .page-hero {
        background:
          linear-gradient(rgba(16, 36, 63, 0.78), rgba(16, 36, 63, 0.78)),
          url("/assets/img/hero/about.jpg");
        background-size: cover;
        background-position: center;
        padding: 120px 0 110px;
      }

      .page-hero h1 {
        color: #fff;
        font-size: 62px;
        font-weight: 700;
        margin-bottom: 12px;
      }

      .page-hero p,
      .hero__caption p,
      .hero-pera p {
        color: rgba(255,255,255,.86);
      }

      .hero__caption h1 span {
        color: #f15f22;
      }

      .dussi-search-box {
        display: flex;
        max-width: 760px;
        margin-top: 30px;
        box-shadow: 0 22px 60px rgba(0,0,0,.18);
      }

      .dussi-search-box .input-form {
        flex: 1;
      }

      .dussi-search-box input,
      .dussi-search-box select {
        height: 68px;
        width: 100%;
        border: 0;
        padding: 0 24px;
        color: #2c234d;
        background: #fff;
      }

      .dussi-search-box .search-form a,
      .dussi-search-box button {
        height: 68px;
        min-width: 190px;
        border: 0;
        background: #f15f22;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        cursor: pointer;
      }

      .btn-brand {
        background: #f15f22;
        color: #fff;
        border: 0;
        display: inline-block;
        padding: 18px 32px;
        border-radius: 5px;
        font-weight: 700;
      }

      .btn-brand:hover {
        color: #fff;
        background: #e0581e;
      }

      .single-cat {
        height: calc(100% - 50px);
      }

      .single-cat .cat-cap p,
      .profile-card p {
        line-height: 1.7;
      }

      .profile-card {
        background: #fff;
        padding: 36px 32px;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(35, 47, 85, 0.08);
        height: 100%;
      }

      .profile-card .eyebrow,
      .eyebrow {
        color: #f15f22;
        display: inline-block;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
      }

      .profile-card h3,
      .blog-card h3,
      .director-card h3 {
        color: #2c234d;
        font-size: 28px;
        line-height: 1.1;
        margin-bottom: 14px;
      }

      .check-list,
      .plain-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .check-list li,
      .plain-list li {
        color: #57667e;
        padding: 10px 0;
        border-bottom: 1px solid #edf0f5;
      }

      .check-list li:before {
        content: "\f00c";
        font-family: "Font Awesome 5 Free";
        font-weight: 900;
        color: #f15f22;
        margin-right: 10px;
      }

      .fact-table {
        width: 100%;
        background: #fff;
        box-shadow: 0 10px 30px rgba(35, 47, 85, 0.08);
      }

      .fact-table th,
      .fact-table td {
        padding: 16px 18px;
        border: 1px solid #edf0f5;
      }

      .fact-table th {
        color: #fff;
        background: var(--dussi-blue);
        width: 34%;
      }

      .section,
      .section-sm {
        padding-top: 90px;
        padding-bottom: 90px;
      }

      .section-soft {
        background: #f9f9f9;
      }

      .section-title {
        margin-bottom: 45px;
      }

      .section-title h2 {
        font-size: 44px;
        color: #2c234d;
        line-height: 1.15;
      }

      .dark-section {
        background:
          linear-gradient(rgba(16, 36, 63, .9), rgba(16, 36, 63, .9)),
          url("/assets/img/gallery/section_bg04.jpg");
        background-size: cover;
        background-position: center;
      }

      .dark-section h2,
      .dark-section p {
        color: #fff;
      }

      .contact-panel,
      .director-card,
      .blog-card,
      .info-panel {
        background: #fff;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(35, 47, 85, 0.08);
        height: 100%;
      }

      .contact-row {
        padding: 13px 0;
        border-bottom: 1px solid #edf0f5;
      }

      .contact-row strong {
        display: block;
        color: #2c234d;
      }

      .director-avatar,
      .card-mark {
        width: 78px;
        height: 78px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #f15f22;
        color: #fff;
        font-size: 22px;
        font-weight: 700;
        margin: 0 auto 20px;
      }

      .director-card {
        text-align: center;
      }

      .g-3 > [class*="col-"],
      .g-4 > [class*="col-"],
      .g-5 > [class*="col-"] {
        margin-bottom: 30px;
      }

      @media (max-width: 767px) {
        .page-hero h1 {
          font-size: 42px;
        }

        .dussi-search-box {
          display: block;
        }

        .dussi-search-box .search-form a,
        .dussi-search-box button {
          width: 100%;
        }

        .section-title h2 {
          font-size: 34px;
        }
      }
    </style>
  </head>
  <body>
    <div id="preloader-active">
      <div class="preloader d-flex align-items-center justify-content-center">
        <div class="preloader-inner position-relative">
          <div class="preloader-circle"></div>
          <div class="preloader-img pere-text">
            <span class="brand-logo"><span>DT</span></span>
          </div>
        </div>
      </div>
    </div>

    <slot />

    <div id="back-top">
      <a title="Go to Top" href="#"><i class="fas fa-level-up-alt"></i></a>
    </div>

    <script is:inline src="/assets/js/vendor/modernizr-3.5.0.min.js"></script>
    <script is:inline src="/assets/js/vendor/jquery-1.12.4.min.js"></script>
    <script is:inline src="/assets/js/popper.min.js"></script>
    <script is:inline src="/assets/js/bootstrap.min.js"></script>
    <script is:inline src="/assets/js/jquery.slicknav.min.js"></script>
    <script is:inline src="/assets/js/owl.carousel.min.js"></script>
    <script is:inline src="/assets/js/slick.min.js"></script>
    <script is:inline src="/assets/js/wow.min.js"></script>
    <script is:inline src="/assets/js/jquery.sticky.js"></script>
    <script is:inline src="/assets/js/jquery.nice-select.min.js"></script>
    <script is:inline src="/assets/js/plugins.js"></script>
    <script is:inline src="/assets/js/main.js"></script>
  </body>
</html>
