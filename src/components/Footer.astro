---
import { company, conventionalMethods } from "../data/company";
---
<footer class="site-footer">
  <div class="container">
    <div class="row g-4">
      <div class="col-lg-4">
        <a class="brand-link text-white mb-3" href="/">
          <span class="brand-mark">DT</span>
          <span>{company.name}</span>
        </a>
        <p>{company.tagline}</p>
        <p>{company.location}. Serving Rwanda, East Africa, and Central Africa.</p>
      </div>
      <div class="col-lg-2 col-md-4">
        <h4>Company</h4>
        <ul class="plain-list">
          <li><a href="/about">About</a></li>
          <li><a href="/leadership">Leadership</a></li>
          <li><a href="/quality">Quality</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="col-lg-3 col-md-4">
        <h4>NDT Methods</h4>
        <ul class="plain-list">
          {conventionalMethods.slice(0, 5).map((method) => (
            <li><a href="/services">{method.title}</a></li>
          ))}
        </ul>
      </div>
      <div class="col-lg-3 col-md-4">
        <h4>Contact</h4>
        <p><strong>Phone:</strong> <a href={`tel:${company.phone.replaceAll(" ", "")}`}>{company.phone}</a></p>
        <p><strong>Mobile:</strong> {company.mobile}</p>
        <p><strong>Email:</strong> <a href={`mailto:${company.email}`}>{company.email}</a></p>
        <p><strong>Website:</strong> {company.website}</p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>Copyright &copy; {new Date().getFullYear()} {company.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
