---
const { name, title, email, mobile } = Astro.props;
const initials = name
  .split(" ")
  .filter(Boolean)
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---
<article class="director-card">
  <div class="director-avatar" aria-hidden="true">{initials}</div>
  <h3>{name}</h3>
  <p class="role">{title}</p>
  {email && <p><a href={`mailto:${email}`}>{email}</a></p>}
  {mobile && <p>{mobile}</p>}
</article>
