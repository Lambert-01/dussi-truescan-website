---
import { company } from "../data/company";

const { activePage = "" } = Astro.props;

const navItems = [
  { href: "/", label: "Home", key: "home" },
  { href: "/about", label: "About", key: "about" },
  { href: "/services", label: "Services", key: "services" },
  { href: "/industries", label: "Industries", key: "industries" },
  { href: "/quality", label: "Quality", key: "quality" },
  { href: "/leadership", label: "Leadership", key: "leadership" },
  { href: "/blog", label: "Blog", key: "blog" },
  { href: "/contact", label: "Contact", key: "contact" },
];
---
<header class="site-header">
  <div class="topbar d-none d-md-block">
    <div class="container d-flex justify-content-between">
      <span>{company.location}</span>
      <span>
        <a href={`tel:${company.phone.replaceAll(" ", "")}`}>{company.phone}</a>
        <span class="mx-2">|</span>
        <a href={`mailto:${company.email}`}>{company.email}</a>
      </span>
    </div>
  </div>
  <div class="container">
    <div class="nav-wrap">
      <a class="brand-link" href="/" aria-label={`${company.name} home`}>
        <span class="brand-mark">DT</span>
        <span>
          {company.shortName}
          <small class="d-block text-muted" style="font-weight:700;">KGL. Ltd</small>
        </span>
      </a>
      <nav class="main-nav" aria-label="Main navigation">
        {navItems.map((item) => (
          <a href={item.href} class={activePage === item.key ? "active" : ""}>{item.label}</a>
        ))}
        <a class="btn-brand" href="/contact">Request Quote</a>
      </nav>
    </div>
  </div>
</header>
