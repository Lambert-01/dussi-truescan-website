---
const { title, text, items = [], eyebrow = "", icon = "" } = Astro.props;
---
<article class="profile-card">
  {icon && <div class="method-icon mb-20"><i class={icon}></i></div>}
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h3>{title}</h3>
  {text && <p>{text}</p>}
  {items.length > 0 && (
    <ul class="check-list">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  )}
</article>
