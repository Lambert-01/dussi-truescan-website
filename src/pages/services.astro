---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProfileCard from "../components/ProfileCard.astro";
import {
  company,
  conventionalMethods,
  advancedMethods,
  consultancyServices,
  trainingServices,
} from "../data/company";

const conventionalIcons = {
  "Ultrasonic Testing (UT)": "fas fa-wave-square",
  "Radiographic Testing (RT)": "fas fa-camera-retro",
  "Magnetic Particle Testing (MT)": "fas fa-magnet",
  "Liquid Penetrant Testing (PT)": "fas fa-tint",
  "Visual Testing (VT)": "fas fa-eye",
  "Eddy Current Testing (ET)": "fas fa-bolt",
};
---
<MainLayout title={`Services | ${company.name}`}>
  <Header activePage="services" />
  <main>
    <section class="page-hero banner-three">
      <div class="container">
        <span class="hero-kicker">Our Services</span>
        <h1>NDT inspection, consultancy, and training.</h1>
        <p>Complete conventional and advanced NDT methods, supported by technical consultancy and professional training programs.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title text-center">
          <span class="eyebrow">Conventional NDT</span>
          <h2>Core testing methods</h2>
        </div>
        <div class="row g-4">
          {conventionalMethods.map((method) => (
            <div class="col-lg-4 col-md-6">
              <ProfileCard title={method.title} text={method.text} icon={conventionalIcons[method.title]} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <div class="row g-4">
          <div class="col-lg-4">
            <ProfileCard
              icon="fas fa-layer-group"
              eyebrow="Advanced NDT"
              title="Specialized methods"
              items={advancedMethods}
            />
          </div>
          <div class="col-lg-4">
            <ProfileCard
              icon="fas fa-clipboard-check"
              eyebrow="Inspection & Consultancy"
              title="Asset integrity support"
              items={consultancyServices}
            />
          </div>
          <div class="col-lg-4">
            <ProfileCard
              icon="fas fa-user-graduate"
              eyebrow="Training"
              title="Professional development"
              items={trainingServices}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section-sm">
      <div class="container">
        <div class="row g-4 align-items-center">
          <div class="col-lg-8">
            <h2>Need a method recommendation?</h2>
            <p>Tell us the asset, material, access limitations, and inspection objective. We will advise the most suitable NDT approach.</p>
          </div>
          <div class="col-lg-4 text-lg-end">
            <a class="btn-brand" href="/contact">Request a Quote</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
