---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import DirectorProfile from "../components/DirectorProfile.astro";
import { company, reasons } from "../data/company";
---
<MainLayout title={`Leadership | ${company.name}`}>
  <Header activePage="leadership" />
  <main>
    <section class="page-hero">
      <div class="container">
        <span class="hero-kicker">Leadership</span>
        <h1>Experienced NDT leadership in Kigali.</h1>
        <p>Founded by NDT professionals and led by Managing Director Emmanuel DUSABIMANA.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="row g-5 align-items-start">
          <div class="col-lg-5">
            <DirectorProfile
              name={company.managingDirector}
              title="Managing Director"
              email={company.directorEmail}
              mobile={company.mobile}
            />
          </div>
          <div class="col-lg-7">
            <div class="section-title">
              <span class="eyebrow">Technical Direction</span>
              <h2>Leadership focused on safety, reliability, and integrity.</h2>
            </div>
            <p>DUSSI TrueScan is led with a practical understanding of industrial inspection needs in Rwanda and the surrounding region. The company profile emphasizes certified personnel, reliable equipment, rapid response, comprehensive reporting, and safety excellence.</p>
            <p>The leadership approach is built around clear communication, internationally recognized NDT standards, and inspection outcomes that help clients make confident decisions about their assets.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <div class="section-title text-center">
          <span class="eyebrow">Operating Principles</span>
          <h2>How the team serves clients</h2>
        </div>
        <div class="info-panel">
          <ul class="check-list">
            {reasons.map((reason) => <li>{reason}</li>)}
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
