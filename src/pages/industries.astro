---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import IndustryCard from "../components/IndustryCard.astro";
import { company, industries } from "../data/company";

const industryIcons = {
  "Construction & Infrastructure": "fas fa-building",
  "Energy & Power Generation": "fas fa-bolt",
  "Mining & Mineral Processing": "fas fa-gem",
  "Manufacturing": "fas fa-industry",
  "Water & Sanitation": "fas fa-tint",
  "Oil & Gas (Regional)": "fas fa-flask",
  "Aviation Industry": "fas fa-plane",
};
---
<MainLayout title={`Industries | ${company.name}`}>
  <Header activePage="industries" />
  <main>
    <section class="page-hero banner-two">
      <div class="container">
        <span class="hero-kicker">Industries We Serve</span>
        <h1>Inspection support for critical sectors.</h1>
        <p>From Kigali, DUSSI TrueScan supports industrial clients across Rwanda, East Africa, and Central Africa.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title text-center">
          <span class="eyebrow">Sectors</span>
          <h2>Industries covered by our profile</h2>
        </div>
        <div class="row g-4">
          {industries.map((industry) => (
            <div class="col-lg-4 col-md-6">
              <IndustryCard title={industry.title} description={industry.text} icon={industryIcons[industry.title]} />
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
