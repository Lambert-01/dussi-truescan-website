---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { company } from "../data/company";
---
<MainLayout title={`About | ${company.name}`}>
  <Header activePage="about" />
  <main>
    <section class="page-hero">
      <div class="container">
        <span class="hero-kicker">About Us</span>
        <h1>Built in Rwanda for reliable asset integrity.</h1>
        <p>{company.name} is a Rwandan-registered Non-Destructive Testing company headquartered in Kigali.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="row g-5 align-items-start">
          <div class="col-lg-7">
            <div class="section-title">
              <span class="eyebrow">Who We Are</span>
              <h2>Comprehensive inspection services, technical consultancy, and professional training.</h2>
            </div>
            <p>{company.name} provides comprehensive inspection services, technical consultancy, and professional training to industries across Rwanda and the East African region. Founded by experienced NDT professionals, we are committed to ensuring the safety, reliability, and integrity of our clients' assets through internationally recognized testing standards and methodologies.</p>
            <p>Our team serves clients in the construction, energy, mining, manufacturing, infrastructure, and aviation sectors. We use calibrated equipment, structured procedures, and clear reporting to deliver accurate and timely inspection results.</p>
          </div>
          <div class="col-lg-5">
            <table class="fact-table">
              <tbody>
                <tr><th>Company Name</th><td>{company.name}</td></tr>
                <tr><th>Year Established</th><td>{company.established}</td></tr>
                <tr><th>Legal Structure</th><td>{company.legalStructure}</td></tr>
                <tr><th>Headquarters</th><td>{company.location}</td></tr>
                <tr><th>TIN</th><td>{company.tin}</td></tr>
                <tr><th>Core Services</th><td>NDT Inspection, Consultancy, Training</td></tr>
                <tr><th>Coverage</th><td>{company.coverage}</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <div class="section-title text-center">
          <span class="eyebrow">Foundation</span>
          <h2>Safety, reliability, and integrity</h2>
          <p class="mx-auto">Every inspection is shaped by technical discipline, impartial judgement, safety awareness, and practical communication.</p>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <article class="profile-card">
              <h3>Mission</h3>
              <p>To deliver reliable inspection, consultancy, and training services that help clients protect people, assets, and operations.</p>
            </article>
          </div>
          <div class="col-md-4">
            <article class="profile-card">
              <h3>Vision</h3>
              <p>To become a trusted NDT and asset integrity partner across Rwanda, East Africa, and Central Africa.</p>
            </article>
          </div>
          <div class="col-md-4">
            <article class="profile-card">
              <h3>Values</h3>
              <p>Integrity, technical excellence, safety, clear reporting, client focus, and continuous improvement.</p>
            </article>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
