---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProfileCard from "../components/ProfileCard.astro";
import { company, qualityStandards } from "../data/company";
---
<MainLayout title={`Quality & Certifications | ${company.name}`}>
  <Header activePage="quality" />
  <main>
    <section class="page-hero banner-three">
      <div class="container">
        <span class="hero-kicker">Quality & Certifications</span>
        <h1>Quality systems behind reliable results.</h1>
        <p>We maintain disciplined inspection practices through aligned standards, calibrated equipment, document control, and qualified personnel.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="row g-4 align-items-start">
          <div class="col-lg-5">
            <div class="section-title mb-0">
              <span class="eyebrow">Our Commitment</span>
              <h2>Clear, controlled, and traceable inspection work.</h2>
              <p>DUSSI TrueScan is committed to maintaining high quality standards through quality management, inspection body practices, personnel certification, audits, calibration, and records management.</p>
            </div>
          </div>
          <div class="col-lg-7">
            <ProfileCard title="Quality framework" items={qualityStandards} />
          </div>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <div class="row g-4">
          <div class="col-md-4">
            <ProfileCard title="Target Certifications" text="ISO 9001:2015 and ISO/IEC 17020 are identified in the company profile as target certification frameworks." />
          </div>
          <div class="col-md-4">
            <ProfileCard title="Personnel Standards" text="Personnel certification practices are aligned with ISO 9712:2021 and international NDT expectations." />
          </div>
          <div class="col-md-4">
            <ProfileCard title="International Standards" text="EN4179 and NAS410 standards are included in the company's quality and certification framework." />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
