---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<MainLayout title="Quality Policy | Dussi TrueScan">
    <Header activePage="quality" />
    <main>
        <div class="slider-area">
            <div class="single-slider hero-overly slider-height2 d-flex align-items-center" data-background="/assets/img/hero/about.jpg">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="hero-cap">
                                <h2>Quality Policy</h2>
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                                        <li class="breadcrumb-item"><a href="#">Quality</a></li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="about-low-area section-padding30">
            <div class="container">
                <div class="row">
                    <div class="col-lg-8 offset-lg-2">
                        <div class="section-tittle text-center mb-60">
                            <span>Our Commitment</span>
                            <h2>Quality is at the Heart of Everything We Do</h2>
                        </div>
                        <p>At Dussi TrueScan, we are committed to providing inspection and quality assurance services of the highest standard. Our quality management approach ensures that every engagement delivers reliable, consistent and technically sound outcomes for our clients.</p>
                    </div>
                </div>
            </div>
        </div>

        <section class="contact-form-area section-bg pt-115 pb-120 fix" data-background="/assets/img/gallery/section_bg02.jpg">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="section-tittle text-center mb-80">
                            <span>Our Standards</span>
                            <h2>Quality Management Framework</h2>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-4 col-md-6 col-sm-6">
                        <div class="single-cat text-center mb-50" style="background:#fff; padding:30px; border-radius:8px;">
                            <div class="cat-icon"><span class="flaticon-shipped"></span></div>
                            <div class="cat-cap">
                                <h5>ISO 9001:2015</h5>
                                <p>Our quality management system is aligned with ISO 9001:2015 principles, ensuring consistent service delivery and continual improvement.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 col-sm-6">
                        <div class="single-cat text-center mb-50" style="background:#fff; padding:30px; border-radius:8px;">
                            <div class="cat-icon"><span class="flaticon-plane"></span></div>
                            <div class="cat-cap">
                                <h5>Independence & Impartiality</h5>
                                <p>We maintain strict independence and impartiality in all our inspection activities, providing clients with objective and unbiased assessments.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 col-sm-6">
                        <div class="single-cat text-center mb-50" style="background:#fff; padding:30px; border-radius:8px;">
                            <div class="cat-icon"><span class="flaticon-ship"></span></div>
                            <div class="cat-cap">
                                <h5>Qualified Inspectors</h5>
                                <p>All our inspectors hold relevant professional qualifications and certifications, with experience across multiple industries and international standards.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="about-low-area section-padding30">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="section-tittle text-center mb-60">
                            <span>Standards We Work To</span>
                            <h2>International Standards & Codes</h2>
                        </div>
                    </div>
                </div>
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <ul style="list-style:none; padding:0; columns:2;">
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> ISO 9001 Quality Management</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> ASME Boiler & Pressure Vessel Code</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> AWS Welding Standards</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> API Standards (API 650, 620, etc.)</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> EN / BS Standards</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> SANS / SABS Standards</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> IEC Electrical Standards</li>
                            <li style="padding:8px 0; border-bottom:1px solid #eee;"><i class="ti-check" style="color:#e7272d; margin-right:8px;"></i> ISO 17020 Inspection Bodies</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</MainLayout>
