---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { company } from "../data/company";
---
<MainLayout title={`Contact | ${company.name}`}>
  <Header activePage="contact" />
  <main>
    <section class="page-hero banner-three">
      <div class="container">
        <span class="hero-kicker">Contact Us</span>
        <h1>Speak with DUSSI TrueScan KGL. Ltd.</h1>
        <p>Send your inspection, consultancy, or training requirement to our Kigali team.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="row g-5">
          <div class="col-lg-7">
            <div class="section-title">
              <span class="eyebrow">Request Information</span>
              <h2>Tell us what you need inspected.</h2>
            </div>
            <form action="#" method="post">
              <div class="row g-3">
                <div class="col-md-6">
                  <input class="form-control" type="text" name="name" placeholder="Your name" />
                </div>
                <div class="col-md-6">
                  <input class="form-control" type="email" name="email" placeholder="Email address" />
                </div>
                <div class="col-md-6">
                  <input class="form-control" type="tel" name="phone" placeholder="Phone number" />
                </div>
                <div class="col-md-6">
                  <select class="form-control" name="service">
                    <option value="">Service required</option>
                    <option>Conventional NDT</option>
                    <option>Advanced NDT</option>
                    <option>Inspection & Consultancy</option>
                    <option>Training & Certification</option>
                  </select>
                </div>
                <div class="col-12">
                  <textarea class="form-control" name="message" placeholder="Project details"></textarea>
                </div>
                <div class="col-12">
                  <button class="btn-brand border-0" type="submit">Send Message</button>
                </div>
              </div>
            </form>
          </div>
          <div class="col-lg-5">
            <aside class="contact-panel">
              <h2>CONTACT US</h2>
              <div class="contact-row">
                <strong>{company.name}</strong>
                <span>{company.location}</span>
              </div>
              <div class="contact-row">
                <strong>Phone</strong>
                <a href={`tel:${company.phone.replaceAll(" ", "")}`}>{company.phone}</a>
              </div>
              <div class="contact-row">
                <strong>Email</strong>
                <a href={`mailto:${company.email}`}>{company.email}</a>
              </div>
              <div class="contact-row">
                <strong>Website</strong>
                <span>{company.website}</span>
              </div>
              <div class="contact-row">
                <strong>Managing Director</strong>
                <span>{company.managingDirector}</span>
              </div>
              <div class="contact-row">
                <strong>Director Email</strong>
                <a href={`mailto:${company.directorEmail}`}>{company.directorEmail}</a>
              </div>
              <div class="contact-row">
                <strong>Mobile</strong>
                <span>{company.mobile}</span>
              </div>
            </aside>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
