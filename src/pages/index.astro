---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ServiceCard from "../components/ServiceCard.astro";
import IndustryCard from "../components/IndustryCard.astro";
import {
  company,
  conventionalMethods,
  industries,
  reasons,
} from "../data/company";
---
<MainLayout title={`${company.name} | NDT Inspection, Consultancy & Training`}>
  <Header activePage="home" />
  <main>
    <section class="hero">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-9">
            <span class="hero-kicker">Kigali, Rwanda - June 2026</span>
            <h1>Non-Destructive Testing for safer, stronger assets.</h1>
            <p>{company.name} provides NDT inspection, technical consultancy, and professional training for construction, energy, mining, manufacturing, infrastructure, and aviation clients across Rwanda and the region.</p>
            <div class="d-flex flex-wrap gap-3 mt-4">
              <a class="btn-brand" href="/services">Explore Services</a>
              <a class="btn-light-brand" href="/contact">Contact Us</a>
            </div>
            <div class="hero-stats">
              <div class="stat-box">
                <strong>{company.established}</strong>
                <span>Year established</span>
              </div>
              <div class="stat-box">
                <strong>8+</strong>
                <span>NDT methods covered</span>
              </div>
              <div class="stat-box">
                <strong>3</strong>
                <span>Regional coverage zones</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title text-center">
          <span class="eyebrow">Company Profile</span>
          <h2>Rwandan-registered NDT inspection, consultancy, and training</h2>
          <p class="mx-auto">Founded by experienced NDT professionals, DUSSI TrueScan helps clients confirm the safety, reliability, and integrity of critical assets using internationally recognized testing standards and methodologies.</p>
        </div>
        <div class="row g-4">
          <div class="col-lg-4 col-md-6">
            <ServiceCard title="Conventional NDT Methods" description="UT, RT, MT, PT, VT, and ET services for flaw detection, surface examination, and thickness measurement." />
          </div>
          <div class="col-lg-4 col-md-6">
            <ServiceCard title="Advanced NDT Methods" description="PAUT, TOFD, digital radiography, LRUT, and acoustic emission testing for complex inspection needs." />
          </div>
          <div class="col-lg-4 col-md-6">
            <ServiceCard title="Inspection & Consultancy" description="Pressure vessels, storage tanks, pipelines, welds, structural integrity, corrosion mapping, and asset integrity support." />
          </div>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container">
        <div class="row g-4 align-items-start">
          <div class="col-lg-5">
            <div class="section-title mb-0">
              <span class="eyebrow">Methods</span>
              <h2>Core inspection capabilities</h2>
              <p>Our team uses calibrated equipment and structured procedures to produce clear, reliable inspection results and practical recommendations.</p>
              <a class="btn-brand mt-3" href="/services">View All Services</a>
            </div>
          </div>
          <div class="col-lg-7">
            <div class="row g-3">
              {conventionalMethods.map((method) => (
                <div class="col-md-6">
                  <article class="profile-card">
                    <h3>{method.title}</h3>
                    <p>{method.text}</p>
                  </article>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title text-center">
          <span class="eyebrow">Industries</span>
          <h2>Sectors we serve</h2>
        </div>
        <div class="row g-4">
          {industries.slice(0, 6).map((industry) => (
            <div class="col-lg-4 col-md-6">
              <IndustryCard title={industry.title} description={industry.text} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section dark-section">
      <div class="container">
        <div class="row g-4 align-items-center">
          <div class="col-lg-5">
            <span class="eyebrow">Why Choose Us</span>
            <h2>Local expertise, global standards.</h2>
            <p>DUSSI TrueScan combines fast local response in Rwanda with international methods, certified personnel, safety discipline, and clear reporting.</p>
          </div>
          <div class="col-lg-7">
            <div class="info-panel">
              <ul class="check-list">
                {reasons.slice(0, 6).map((reason) => <li>{reason}</li>)}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-sm">
      <div class="container">
        <div class="row g-4 align-items-center">
          <div class="col-lg-8">
            <span class="eyebrow">Ready to inspect?</span>
            <h2>Talk to DUSSI TrueScan about your project.</h2>
            <p>Share your inspection, consultancy, or training requirement and our Kigali team will respond with practical next steps.</p>
          </div>
          <div class="col-lg-4 text-lg-end">
            <a class="btn-brand" href="/contact">Request a Quote</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
