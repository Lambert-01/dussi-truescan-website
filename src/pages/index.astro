---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ServiceCard from "../components/ServiceCard.astro";
import IndustryCard from "../components/IndustryCard.astro";
import { company, conventionalMethods, industries, reasons, blogPosts } from "../data/company";
---
<MainLayout title={`${company.name} | NDT Inspection, Consultancy & Training`}>
  <Header activePage="home" />
  <main>
    <div class="slider-area">
      <div class="slider-active">
        <div class="single-slider slider-height dussi-slider d-flex align-items-center">
          <div class="container">
            <div class="row">
              <div class="col-xl-9 col-lg-10">
                <div class="hero__caption">
                  <h1>Reliable <span>NDT Inspection</span> Solutions!</h1>
                  <p>{company.tagline} from Kigali, Rwanda.</p>
                </div>
                <form action="/contact" class="dussi-search-box">
                  <div class="input-form">
                    <input type="text" placeholder="Tell us your asset, weld, tank, pipeline or training need" />
                  </div>
                  <div class="search-form">
                    <a href="/contact">Request Quote</a>
                  </div>
                </form>
                <div class="hero-pera">
                  <p>Serving Rwanda, East Africa, and Central Africa</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="single-slider slider-height dussi-slider banner-two d-flex align-items-center">
          <div class="container">
            <div class="row">
              <div class="col-xl-9 col-lg-10">
                <div class="hero__caption">
                  <h1>Precision <span>Inspection</span> For Critical Assets.</h1>
                  <p>Ultrasonic, radiographic, magnetic particle, penetrant, visual and eddy current testing for industrial confidence.</p>
                </div>
                <div class="hero-pera">
                  <p>Construction | Energy | Mining | Manufacturing | Aviation</p>
                </div>
                <a href="/services" class="btn hero-btn mt-30">Explore Services</a>
              </div>
            </div>
          </div>
        </div>
        <div class="single-slider slider-height dussi-slider banner-three d-flex align-items-center">
          <div class="container">
            <div class="row">
              <div class="col-xl-9 col-lg-10">
                <div class="hero__caption">
                  <h1>Training, <span>Consultancy</span> & Quality Support.</h1>
                  <p>Professional NDT training, asset integrity consultancy, inspection reporting and standards-driven quality systems.</p>
                </div>
                <div class="hero-pera">
                  <p>ISO 9712 | ISO/IEC 17020 | API 510 | API 653 | EN4179 / NAS410</p>
                </div>
                <a href="/contact" class="btn hero-btn mt-30">Talk To Our Team</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="our-info-area pt-70 pb-40">
      <div class="container">
        <div class="row">
          <div class="col-lg-4 col-md-6 col-sm-6">
            <div class="single-info mb-30">
              <div class="info-icon"><span class="flaticon-support"></span></div>
              <div class="info-caption">
                <p>Call Us Anytime</p>
                <span>{company.phone}</span>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6 col-sm-6">
            <div class="single-info mb-30">
              <div class="info-icon"><span class="flaticon-clock"></span></div>
              <div class="info-caption">
                <p>Established</p>
                <span>{company.established} | Certified NDT Focus</span>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6 col-sm-6">
            <div class="single-info mb-30">
              <div class="info-icon"><span class="flaticon-place"></span></div>
              <div class="info-caption">
                <p>{company.location}</p>
                <span>{company.coverage}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="categories-area section-padding30">
      <div class="container">
        <div class="row">
          <div class="col-lg-12">
            <div class="section-tittle text-center mb-80">
              <span>Our Services</span>
              <h2>What We Can Do For You</h2>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-lg-4 col-md-6 col-sm-6">
            <ServiceCard icon="flaticon-shipped" title="Conventional NDT" description="UT, RT, MT, PT, VT and ET services for flaw detection, surface examination, and thickness measurement." />
          </div>
          <div class="col-lg-4 col-md-6 col-sm-6">
            <ServiceCard icon="flaticon-ship" title="Advanced NDT" description="PAUT, TOFD, digital radiography, LRUT and acoustic emission testing for complex inspection needs." />
          </div>
          <div class="col-lg-4 col-md-6 col-sm-6">
            <ServiceCard icon="flaticon-plane" title="Consultancy & Training" description="Asset integrity consultancy, API inspections, weld qualification, NDT training and HSE/QMS courses." />
          </div>
        </div>
      </div>
    </div>

    <div class="about-low-area padding-bottom">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-6 col-md-12">
            <div class="about-caption mb-50">
              <div class="section-tittle mb-35">
                <span>About Our Company</span>
                <h2>Rwandan NDT professionals protecting critical assets.</h2>
              </div>
              <p>{company.name} is a Rwandan-registered Non-Destructive Testing company providing inspection services, technical consultancy, and professional training.</p>
              <p>Our Kigali-based team helps construction, energy, mining, manufacturing, infrastructure, and aviation clients verify safety, reliability, and integrity.</p>
              <a href="/about" class="btn">More About Us</a>
            </div>
          </div>
          <div class="col-lg-6 col-md-12">
            <div class="dussi-about-visual">
              <img src="/assets/img/dussi/banner2.png" alt="DUSSI TrueScan inspection services" />
              <div class="about-visual-badge">
                <strong>NDT</strong>
                <span>Inspection | Consultancy | Training</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="contact-form-area section-bg dussi-worker-quote pt-115 pb-120 fix" data-background="/assets/img/dussi/worker.png">
      <div class="container">
        <div class="row justify-content-end">
          <div class="col-xl-8 col-lg-9">
            <div class="contact-form-wrapper">
              <div class="row">
                <div class="col-lg-12">
                  <div class="section-tittle mb-50">
                    <span>Get a Quote For Free</span>
                    <h2>Request a Free Quote</h2>
                    <p>Tell us about your inspection, consultancy, or training requirement and our team will respond promptly.</p>
                  </div>
                </div>
              </div>
              <form action="/contact" class="contact-form">
                <div class="row">
                  <div class="col-lg-6 col-md-6"><div class="input-form"><input type="text" placeholder="Name" /></div></div>
                  <div class="col-lg-6 col-md-6"><div class="input-form"><input type="email" placeholder="Email" /></div></div>
                  <div class="col-lg-12"><div class="input-form"><input type="text" placeholder="Contact Number" /></div></div>
                  <div class="col-lg-6">
                    <div class="select-items">
                      <select name="service">
                        <option value="">Service Required</option>
                        <option>Conventional NDT</option>
                        <option>Advanced NDT</option>
                        <option>Inspection Consultancy</option>
                        <option>Training & Certification</option>
                      </select>
                    </div>
                  </div>
                  <div class="col-lg-6 col-md-6"><div class="input-form"><input type="text" placeholder="Company / Project" /></div></div>
                  <div class="col-lg-12"><button name="submit" class="submit-btn">Request a Quote</button></div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="categories-area section-padding30">
      <div class="container">
        <div class="section-tittle text-center mb-80">
          <span>Industries We Serve</span>
          <h2>Critical Sectors Across The Region</h2>
        </div>
        <div class="row">
          {industries.slice(0, 6).map((industry) => (
            <div class="col-lg-4 col-md-6 col-sm-6">
              <IndustryCard title={industry.title} description={industry.text} />
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="testimonial-area testimonial-padding section-bg" data-background="/assets/img/gallery/section_bg04.jpg">
      <div class="container">
        <div class="row justify-content-between">
          <div class="col-xl-7 col-lg-7">
            <div class="section-tittle section-tittle2 mb-25">
              <span>Why Choose DUSSI TrueScan</span>
              <h2>Committed to Excellence in Every Inspection</h2>
            </div>
            <div class="single-testimonial">
              <div class="testimonial-caption">
                <div class="testimonial-top-cap">
                  <p>{reasons.slice(0, 4).join(". ")}.</p>
                </div>
                <div class="testimonial-founder d-flex align-items-center">
                  <div class="founder-img"><img src="/assets/img/dussi/logo.png" alt={company.shortName} /></div>
                  <div class="founder-text">
                    <span>{company.managingDirector}</span>
                    <p>Managing Director</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-4 col-lg-5 col-md-8">
            <div class="testimonial-form text-center">
              <h3>Always ready for reliable inspection support.</h3>
              <input type="text" placeholder={company.email} />
              <a href="/contact" class="submit-btn d-block">Contact Us Today</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="home-blog-area section-padding30">
      <div class="container">
        <div class="section-tittle text-center mb-70">
          <span>Our Blog</span>
          <h2>Inspection & Quality Insights</h2>
        </div>
        <div class="row">
          {blogPosts.map((post) => (
            <div class="col-lg-4 col-md-6">
              <article class="profile-card mb-30">
                <span class="eyebrow">{post.category}</span>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
                <a href="/blog" class="btn mt-20">Read More</a>
              </article>
            </div>
          ))}
        </div>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
